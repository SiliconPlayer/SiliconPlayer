+static UINT8
+OPSG_GetChannelScope(
+	void*		chip,
+	UINT32		channel,
+	UINT32		samples,
+	DEV_SMPL**	outputs)
+{
+	huc6280_state* info = (huc6280_state*)chip;
+	UINT32 samplesToCopy;
+
+	if (channel >= N_CHANNEL || outputs == NULL || outputs[0] == NULL || outputs[1] == NULL || info->scopeData == NULL)
+		return 0xFF;
+	samplesToCopy = (samples < info->scopeSampleCount) ? samples : info->scopeSampleCount;
+	memcpy(outputs[0], &info->scopeData[(channel * 2 + 0) * info->scopeBufferSize], samplesToCopy * sizeof(DEV_SMPL));
+	memcpy(outputs[1], &info->scopeData[(channel * 2 + 1) * info->scopeBufferSize], samplesToCopy * sizeof(DEV_SMPL));
+	if (samplesToCopy < samples)
+	{
+		memset(&outputs[0][samplesToCopy], 0, (samples - samplesToCopy) * sizeof(DEV_SMPL));
+		memset(&outputs[1][samplesToCopy], 0, (samples - samplesToCopy) * sizeof(DEV_SMPL));
+	}
+	return 0x00;
+}
