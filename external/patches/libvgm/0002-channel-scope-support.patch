+void VGMPlayer::SetChannelScopeEnabled(UINT8 enabled)
+{
+	_scopeEnabled = enabled;
+	if (!enabled)
+	{
+		_scopeBuffers.clear();
+		_scopeSampleCount = 0;
+	}
+	return;
+}
+
+UINT8 VGMPlayer::GetChannelScopeSamples(UINT32 devID, UINT32 channel, UINT32 sampleCount, WAVE_32BS* sampleBuffer) const
+{
+	if (!_scopeEnabled || devID >= _scopeBuffers.size())
+		return 0xFF;
+
+	const auto& scopeDev = _scopeBuffers[devID];
+	if (channel >= scopeDev.channelBuffers.size())
+		return 0xFF;
+	const auto& scopeBuf = scopeDev.channelBuffers[channel];
+	UINT32 samplesToCopy = std::min(sampleCount, static_cast<UINT32>(scopeBuf.size()));
+	for (UINT32 i = 0; i < samplesToCopy; ++i)
+	{
+		sampleBuffer[i] = scopeBuf[i];
+	}
 	return 0x00;
 }
 
+UINT32 VGMPlayer::GetChannelScopeDeviceCount(void) const
+{
+	if (!_scopeEnabled)
+		return 0;
+	return static_cast<UINT32>(_scopeBuffers.size());
+}
+
+UINT32 VGMPlayer::GetChannelScopeSampleCount(void) const
+{
+	if (!_scopeEnabled || _scopeBuffers.empty())
+		return 0;
+	return _scopeSampleCount;
+}
+
+void VGMPlayer::ResizeScopeBuffers(UINT32 sampleCount)
+{
+	size_t devCount = _devices.size();
+	if (_scopeBuffers.size() != devCount)
+		_scopeBuffers.resize(devCount);
+
+	for (size_t i = 0; i < devCount; ++i)
+	{
+		SCOPE_DEVICE& scopeDev = _scopeBuffers[i];
+		CHIP_DEVICE& chipDev = _devices[i];
+		const DEV_GEN_CFG* devCfg = (chipDev.cfgID < _devCfgs.size() && ! _devCfgs[chipDev.cfgID].cfgData.empty())
+			? (const DEV_GEN_CFG*)&_devCfgs[chipDev.cfgID].cfgData[0]
+			: NULL;
+		UINT32 channelCount = 0;
+		if (chipDev.base.defInf.devDecl != NULL && chipDev.base.defInf.devDecl->channelCount != NULL)
+			channelCount = chipDev.base.defInf.devDecl->channelCount(devCfg);
+		scopeDev.channelCount = channelCount;
+		scopeDev.channelBuffers.resize(channelCount);
+		for (UINT32 channel = 0; channel < channelCount; ++channel)
+			scopeDev.channelBuffers[channel].resize(sampleCount);
+	}
+	_scopeSampleCount = sampleCount;
+}
+
+void VGMPlayer::ClearScopeBuffers(UINT32 startIdx, UINT32 count)
+{
+	for (auto& scopeDev : _scopeBuffers)
+	{
+		for (auto& buf : scopeDev.channelBuffers)
+		{
+			UINT32 endIdx = std::min(startIdx + count, static_cast<UINT32>(buf.size()));
+			for (UINT32 i = startIdx; i < endIdx; ++i)
+			{
+				buf[i].L = 0;
+				buf[i].R = 0;
+			}
+		}
+	}
+}
+
+static void MixWave32(WAVE_32BS* dest, const WAVE_32BS* src, UINT32 count)
+{
+	for (UINT32 i = 0; i < count; ++i)
+	{
+		dest[i].L += src[i].L;
+		dest[i].R += src[i].R;
+	}
+}
