+static void Resmpl_EnsureScopeBuffers(RESMPL_STATE* CAA, UINT32 channels, UINT32 length)
+{
+	if (! channels || ! length)
+		return;
+	if (CAA->scopeBufSize < length || CAA->scopeBufChannels < channels)
+	{
+		free(CAA->scopeBufData);
+		free(CAA->scopeLast);
+		free(CAA->scopeNext);
+
+		CAA->scopeBufSize = length;
+		CAA->scopeBufChannels = channels;
+		CAA->scopeBufData = (DEV_SMPL*)malloc(channels * 2 * length * sizeof(DEV_SMPL));
+		CAA->scopeLast = (WAVE_32BS*)calloc(channels, sizeof(WAVE_32BS));
+		CAA->scopeNext = (WAVE_32BS*)calloc(channels, sizeof(WAVE_32BS));
+		if (CAA->scopeBufData == NULL || CAA->scopeLast == NULL || CAA->scopeNext == NULL)
+			abort();
+	}
+}
+
+static DEV_SMPL* Resmpl_ScopeBufL(RESMPL_STATE* CAA, UINT32 channel)
+{
+	return &CAA->scopeBufData[(channel * 2 + 0) * CAA->scopeBufSize];
+}
+
+static DEV_SMPL* Resmpl_ScopeBufR(RESMPL_STATE* CAA, UINT32 channel)
+{
+	return &CAA->scopeBufData[(channel * 2 + 1) * CAA->scopeBufSize];
+}
+
+static void Resmpl_LoadScope(RESMPL_STATE* CAA, UINT32 offset, UINT32 samples)
+{
+	UINT32 channel;
+
+	if (CAA->ScopeUpdate == NULL || CAA->scopeOutputs == NULL || ! CAA->scopeChannelCount || ! samples)
+		return;
+	Resmpl_EnsureScopeBuffers(CAA, CAA->scopeChannelCount, offset + samples);
+	for (channel = 0; channel < CAA->scopeChannelCount; channel ++)
+	{
+		DEV_SMPL* outputs[2];
+		UINT8 retVal;
+
+		outputs[0] = Resmpl_ScopeBufL(CAA, channel) + offset;
+		outputs[1] = Resmpl_ScopeBufR(CAA, channel) + offset;
+		retVal = CAA->ScopeUpdate(CAA->su_DataPtr, channel, samples, outputs);
+		if (retVal != 0x00)
+		{
+			memset(outputs[0], 0, samples * sizeof(DEV_SMPL));
+			memset(outputs[1], 0, samples * sizeof(DEV_SMPL));
+		}
+	}
+}
+
+static void Resmpl_AddScopeSample(RESMPL_STATE* CAA, UINT32 channel, UINT32 outPos, INT64 left, INT64 right, INT64 divisor)
+{
+	WAVE_32BS* output;
+
+	if (CAA->scopeOutputs == NULL || channel >= CAA->scopeChannelCount || CAA->scopeOutputs[channel] == NULL)
+		return;
+	output = CAA->scopeOutputs[channel];
+	output[outPos].L += (DEV_SMPL)(left * CAA->volumeL / divisor);
+	output[outPos].R += (DEV_SMPL)(right * CAA->volumeR / divisor);
+}
+
